{
  "name": "aicloud",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:frontend": "npm run dev -w @aicloud/frontend",
    "compose:config": "docker compose config"
  },
  "engines": {
    "node": ">=20"
  }
}
