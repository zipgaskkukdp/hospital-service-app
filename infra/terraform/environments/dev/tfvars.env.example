# Example TF_VAR environment file.
# Copy to tfvars.env.local, fill placeholders, then source it locally.
# Do not commit tfvars.env.local.
# Do not put secrets here.

export TF_VAR_aws_region="ap-northeast-2"
export TF_VAR_project_name="ai-care"
export TF_VAR_environment="dev"
export TF_VAR_tags='{}'

# Console-managed Service network.
export TF_VAR_service_vpc_id="vpc-service-xxxxxxxx"
export TF_VAR_service_public_subnet_ids='["subnet-service-public-a","subnet-service-public-c"]'
export TF_VAR_service_private_app_subnet_ids='["subnet-service-private-app-a","subnet-service-private-app-c"]'
export TF_VAR_service_private_data_subnet_ids='["subnet-service-private-data-a","subnet-service-private-data-c"]'
export TF_VAR_service_internet_gateway_id="igw-service-xxxxxxxx"
export TF_VAR_service_public_route_table_ids='["rtb-service-public-a","rtb-service-public-c"]'
# Must be the route table associated with the EKS worker node subnets. Current
# dev worker node subnets are subnet-0399d1d5dc9043b69 and
# subnet-05a7f50d03159ee6f. Do not put public or private data route table IDs
# here, or nodes may miss NAT egress and fail with NodeCreationFailure.
export TF_VAR_service_private_app_route_table_ids='["rtb-service-private-app-a","rtb-service-private-app-c"]'
export TF_VAR_service_private_data_route_table_ids='["rtb-service-private-data-a","rtb-service-private-data-c"]'

# Console-managed On-Prem network. Do not use the Service VPC IGW here.
export TF_VAR_onprem_vpc_id="vpc-onprem-xxxxxxxx"
export TF_VAR_onprem_public_subnet_id="subnet-onprem-public"
export TF_VAR_onprem_private_subnet_id="subnet-onprem-private"
export TF_VAR_onprem_internet_gateway_id="igw-onprem-xxxxxxxx"
export TF_VAR_onprem_public_route_table_id="rtb-onprem-public"
export TF_VAR_onprem_private_route_table_id="rtb-onprem-private"
export TF_VAR_onprem_ec2_key_name=""

# Console-managed routes:
# - Service Public Route Table: 0.0.0.0/0 -> Service IGW
# - On-Prem Public Route Table: 0.0.0.0/0 -> On-Prem IGW
#
# Terraform-managed routes:
# - Service Private App Route Table: 0.0.0.0/0 -> Service NAT Gateway
# - Service Private App Route Table: 172.16.0.0/16 -> VGW
# - On-Prem Private Route Table: 10.0.0.0/16 -> strongSwan ENI
export TF_VAR_create_service_nat_gateway=true

export TF_VAR_reports_bucket_name="ai-care-dev-reports-<account-id>"
export TF_VAR_reports_s3_prefix="reports/"

export TF_VAR_cluster_public_access_cidrs='["x.x.x.x/32"]'

export TF_VAR_app_ecr_repository_names='["auth-user-service","questionnaire-service","ai-triage-service","hospital-recommendation-service","onprem-sensitive-api"]'

export TF_VAR_create_ai_processor_lambda=false
export TF_VAR_ai_processor_image_uri=""

export TF_VAR_enable_cicd=false
export TF_VAR_create_github_oidc_provider=false
export TF_VAR_github_oidc_provider_arn=""
export TF_VAR_github_repository="zipgaskkukdp/hospital-service-app"
export TF_VAR_github_branch="main"
